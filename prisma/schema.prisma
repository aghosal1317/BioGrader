generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?

  role                UserRole  @default(STUDENT)
  mustChangePassword  Boolean   @default(false)

  // For students: which teacher created/owns them
  teacherId      String?
  teacher        User?   @relation("TeacherStudents", fields: [teacherId], references: [id])
  students       User[]  @relation("TeacherStudents")

  grade            Int?
  subjectInterests String[]
  timezone         String?

  // School / academic info
  school       String?  // e.g. "Lincoln High School"
  county       String?  // e.g. "Wake County"
  state        String?  // e.g. "NC"
  schoolType   String?  // "public" | "private" | "charter" | "homeschool" | "other"
  classSection String?  // e.g. "Period 3" or "Block B"
  schoolYear   String?  // e.g. "2024-2025"
  apExamYear   Int?     // year the student plans to take the AP Bio exam

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  passwordResets PasswordReset[]
  submissions    Submission[]
  drafts         Draft[]
  userStats      UserStats?
  mcqAttempts    MCQAttempt[]

  @@index([teacherId])
  @@map("users")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ─── Content ─────────────────────────────────────────────────────────────────

model Topic {
  id     String @id @default(cuid())
  name   String @unique
  apUnit Int
  slug   String @unique

  frqs FRQ[]

  @@map("topics")
}

model FRQ {
  id          String     @id @default(cuid())
  year        Int
  questionNum Int
  type        FRQType    @default(LONG)
  difficulty  Difficulty @default(MEDIUM)
  topicId     String
  summary     String?

  prompt      String   @db.Text
  imageUrls   String[]
  totalPoints Int

  // RubricCategory[] stored as JSON
  rubric Json

  source     String?
  isOfficial Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id])
  submissions Submission[]
  drafts      Draft[]

  @@unique([year, questionNum])
  @@index([topicId])
  @@index([year])
  @@index([difficulty])
  @@map("frqs")
}

enum FRQType {
  LONG
  SHORT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─── User Activity ───────────────────────────────────────────────────────────

model Draft {
  id        String   @id @default(cuid())
  userId    String
  frqId     String
  content   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  frq  FRQ  @relation(fields: [frqId], references: [id])

  @@unique([userId, frqId])
  @@map("drafts")
}

model Submission {
  id String @id @default(cuid())

  userId String
  frqId  String

  answerContent Json
  answerText    String @db.Text

  status       SubmissionStatus @default(PENDING)
  totalScore   Int?
  maxScore     Int?
  gradingResult Json?

  timeSpentSec Int       @default(0)
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  frq  FRQ  @relation(fields: [frqId], references: [id])

  @@index([userId])
  @@index([frqId])
  @@index([userId, submittedAt])
  @@map("submissions")
}

enum SubmissionStatus {
  PENDING
  GRADING
  GRADED
  FAILED
}

// ─── MCQ ─────────────────────────────────────────────────────────────────────

model MCQ {
  id          String     @id @default(cuid())
  question    String     @db.Text
  options     Json       // { A: string, B: string, C: string, D: string }
  answer      String     // "A" | "B" | "C" | "D"
  explanation String     @db.Text
  unit        Int        // AP Bio unit 1-8
  topicSlug   String
  difficulty  Difficulty @default(MEDIUM)
  year        Int?       // exam year if from a real test

  createdAt DateTime @default(now())

  attempts MCQAttempt[]

  @@index([unit])
  @@index([topicSlug])
  @@map("mcqs")
}

model MCQAttempt {
  id      String  @id @default(cuid())
  userId  String
  mcqId   String
  answer  String  // what the user selected
  correct Boolean
  unit    Int     // denormalized for fast unit-level queries

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq  MCQ  @relation(fields: [mcqId], references: [id])

  @@index([userId])
  @@index([userId, unit])
  @@map("mcq_attempts")
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model UserStats {
  id     String @id @default(cuid())
  userId String @unique

  totalSubmissions  Int      @default(0)
  totalTimeSpentSec Int      @default(0)
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastActivityAt    DateTime?

  // Record<topicSlug, { attempts: number; avgScore: number }>
  topicStats Json @default("{}")

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}
